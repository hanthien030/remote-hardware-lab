# Root environment variables for docker-compose and backend services

# MySQL
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=remote_lab

# Flask / backend
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace_with_a_strong_random_secret

# Database connection used by backend
DB_HOST=database
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=remote_lab
DB_PORT=3306

# Internal service communication
INTERNAL_API_KEY=replace_with_a_long_random_internal_api_key
LISTENER_POLLING_INTERVAL=5

# Service URLs inside docker network
BROKER_URL=http://broker:8000
